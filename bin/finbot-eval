#!/usr/bin/env node
/**
 * finbot-eval — forecast-evaluation + risk/reward sweep over the synthetic
 * oracle fixtures and the three instrument types.
 *
 * Usage:
 *   finbot-eval
 *   finbot-eval --horizon=32 --ensemble=300 --realizations=500
 *   finbot-eval --instrument-horizon=64 --instrument-realizations=400
 *
 * Flags:
 *   --horizon=N                forecast horizon (ticks), default 32
 *   --ensemble=N               forecaster ensemble size, default 300
 *   --realizations=N           held-out realizations per preset, default 500
 *   --instrument-horizon=N     instrument-sweep horizon, default 64
 *   --instrument-realizations=N  instrument-sweep realizations, default 400
 *   --vol-length=N             walk-forward vol-eval series length, default 256
 *   --vol-train-fraction=F     walk-forward train/test split, default 0.6
 *   --help / -h                print this and exit
 *
 * Everything is seeded; two runs with the same flags print identical
 * tables. Simulation only — no funds, no chain. See the @finbot/simulator
 * README § Forecast evaluation for what the tables mean.
 */

import process from 'node:process';

import { runEvaluation, renderEvaluationText } from '../packages/simulator/evaluation.js';
import { walkForwardVolEval, renderVolEvalText } from '../packages/simulator/vol-eval.js';
import { PRESETS, generate } from '../packages/simulator/test/fixtures/presets.js';

function parseArgs(argv) {
  const args = {
    horizon: 32,
    ensemble: 300,
    realizations: 500,
    instrumentHorizon: 64,
    instrumentRealizations: 400,
    volLength: 256,
    volTrainFraction: 0.6,
  };
  for (const arg of argv) {
    const eq = arg.indexOf('=');
    const key = eq >= 0 ? arg.slice(0, eq) : arg;
    const val = eq >= 0 ? arg.slice(eq + 1) : null;
    if (key === '--horizon') args.horizon = Number(val);
    else if (key === '--ensemble') args.ensemble = Number(val);
    else if (key === '--realizations') args.realizations = Number(val);
    else if (key === '--instrument-horizon') args.instrumentHorizon = Number(val);
    else if (key === '--instrument-realizations') args.instrumentRealizations = Number(val);
    else if (key === '--vol-length') args.volLength = Number(val);
    else if (key === '--vol-train-fraction') args.volTrainFraction = Number(val);
    else if (key === '--help' || key === '-h') {
      // eslint-disable-next-line no-console
      console.log([
        'finbot-eval — forecast evaluation + risk/reward sweep',
        '',
        'Usage:',
        '  finbot-eval [--horizon=N] [--ensemble=N] [--realizations=N]',
        '              [--instrument-horizon=N] [--instrument-realizations=N]',
      ].join('\n'));
      process.exit(0);
    }
  }
  return args;
}

const args = parseArgs(process.argv.slice(2));

const result = runEvaluation({
  presets: PRESETS,
  generate,
  forecastEval: {
    horizon: args.horizon,
    ensembleSize: args.ensemble,
    realizationCount: args.realizations,
  },
  instruments: {
    horizon: args.instrumentHorizon,
    realizationCount: args.instrumentRealizations,
  },
});

process.stdout.write(renderEvaluationText(result));

// --- Walk-forward OOS volatility-forecast evaluation. ---
// Scores the one-step-ahead conditional variance of every GARCH-family model
// against three naive baselines (constant, EWMA, rolling window), strictly out
// of sample, on each fixture preset. QLIKE and MSE; lower is better. The naive
// column is the honesty check — a GARCH model that cannot beat the flat number
// on a given preset is not earning its complexity there.
const volLines = ['', '', '=== walk-forward volatility evaluation (one-step-ahead, OOS) ==='];
for (const preset of PRESETS) {
  const { series } = generate(preset, { length: args.volLength });
  const table = walkForwardVolEval(series, { trainFraction: args.volTrainFraction });
  volLines.push('', renderVolEvalText(table, { title: preset.name }));
}
process.stdout.write(`${volLines.join('\n')}\n`);
